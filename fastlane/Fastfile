default_platform(:ios)

platform :ios do
  desc "Run unit tests"
  lane :test do
    run_tests(
      scheme: "WoofWalk",
      devices: ["iPhone 15 Pro"],
      clean: true,
      code_coverage: true,
      derived_data_path: "DerivedData",
      output_directory: "fastlane/test_output"
    )
  end

  desc "Run UI tests"
  lane :ui_test do
    run_tests(
      scheme: "WoofWalk",
      devices: ["iPhone 15 Pro"],
      only_testing: ["WoofWalkUITests"],
      clean: true,
      derived_data_path: "DerivedData",
      output_directory: "fastlane/test_output"
    )
  end

  desc "Run all tests with coverage"
  lane :test_all do
    run_tests(
      scheme: "WoofWalk",
      devices: ["iPhone 15 Pro"],
      clean: true,
      code_coverage: true,
      derived_data_path: "DerivedData",
      output_directory: "fastlane/test_output",
      result_bundle: true
    )

    slather(
      proj: "WoofWalk.xcodeproj",
      scheme: "WoofWalk",
      output_directory: "fastlane/test_output/coverage",
      html: true,
      show: false
    )
  end

  desc "Build app for testing"
  lane :build_for_testing do
    build_app(
      scheme: "WoofWalk",
      configuration: "Debug",
      build_for_testing: true,
      derived_data_path: "DerivedData"
    )
  end

  desc "Run tests without building"
  lane :test_without_building do
    run_tests(
      scheme: "WoofWalk",
      devices: ["iPhone 15 Pro"],
      test_without_building: true,
      derived_data_path: "DerivedData",
      output_directory: "fastlane/test_output"
    )
  end

  desc "Lint code"
  lane :lint do
    swiftlint(
      mode: :lint,
      executable: "Pods/SwiftLint/swiftlint",
      config_file: ".swiftlint.yml",
      raise_if_swiftlint_error: true
    )
  end

  desc "Build for App Store"
  lane :release do
    increment_build_number(xcodeproj: "WoofWalk.xcodeproj")

    build_app(
      scheme: "WoofWalk",
      configuration: "Release",
      export_method: "app-store"
    )
  end

  desc "Authenticate to App Store Connect via API key (read from env)."
  desc "Sets the credentials in fastlane's session so subsequent actions"
  desc "(match, gym/build_app, pilot/upload_to_testflight) don't need to"
  desc "re-prompt for an Apple ID password. Required env vars:"
  desc "  APP_STORE_CONNECT_KEY_ID, APP_STORE_CONNECT_ISSUER_ID,"
  desc "  APP_STORE_CONNECT_API_KEY_CONTENT (the .p8 file body, multi-line)"
  lane :asc_auth do
    app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: false,
      in_house: false
    )
  end

  desc "Sync (or bootstrap) Distribution + Provisioning Profile via match"
  desc "into the woofwalk-ios-certs repo. Reads in readonly mode in CI so"
  desc "every job doesn't try to regenerate; set MATCH_READONLY=false for"
  desc "the one-time bootstrap that generates the cert."
  lane :certs do
    asc_auth
    match(
      type: "appstore",
      readonly: ENV["MATCH_READONLY"] != "false",
      # generate_apple_certs lets match talk to Apple via the ASC API key
      # instead of the legacy spaceship flow (which needs an Apple ID password).
      generate_apple_certs: true
    )
  end

  desc "Build + upload to TestFlight. Self-contained: pulls certs, bumps"
  desc "build number, archives, signs, uploads. Run from GitHub Actions."
  lane :beta do
    asc_auth

    # Pull certs in readonly mode — match repo must already be populated
    # by a prior `fastlane certs` bootstrap run.
    match(type: "appstore", readonly: true, generate_apple_certs: true)

    # Build number: use number of commits so it's monotonic and reproducible
    # without needing to commit back to the repo (avoids a CI write loop).
    build_num = sh("git", "rev-list", "--count", "HEAD").strip
    increment_build_number(
      xcodeproj: "WoofWalk.xcodeproj",
      build_number: build_num
    )

    build_app(
      workspace: "WoofWalk.xcworkspace",
      scheme: "WoofWalk",
      configuration: "Release",
      export_method: "app-store",
      # The Xcode project pre-dated the developer account so it has no
      # DEVELOPMENT_TEAM baked in. We pass it via xcargs rather than mutating
      # project.pbxproj — keeps the project file clean and means there's
      # nothing to commit when the team rotates. CODE_SIGN_STYLE=Manual is
      # required because match generates explicit profiles; if Xcode is
      # left in Automatic it'll try to generate its own profile and ignore
      # match's.
      xcargs: "DEVELOPMENT_TEAM=6439W9DW5X CODE_SIGN_STYLE=Manual",
      export_options: {
        provisioningProfiles: {
          "com.woofwalk.ios" => "match AppStore com.woofwalk.ios",
          "com.woofwalk.ios.watchkitapp" => "match AppStore com.woofwalk.ios.watchkitapp"
        }
      }
    )

    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      # CI flag: don't prompt for compliance/marketing answers; we'll set
      # those in App Store Connect once before the first TestFlight push.
      skip_submission: false
    )
  end

  desc "Take screenshots"
  lane :screenshots do
    capture_screenshots(
      scheme: "WoofWalkUITests",
      devices: [
        "iPhone 15 Pro",
        "iPhone 15 Pro Max",
        "iPad Pro (12.9-inch)"
      ]
    )
  end

  desc "Clean build artifacts"
  lane :clean_build do
    clean_build_artifacts
    clear_derived_data
  end

  error do |lane, exception|
    notification(
      title: "Fastlane",
      message: "Error in lane #{lane}: #{exception.message}"
    )
  end
end
