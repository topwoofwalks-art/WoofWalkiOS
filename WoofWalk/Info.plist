	<!--
	  Custom URL scheme `woofwalk://` — matches Android's
	  AndroidManifest.xml lines 98-126. Used by:
	    * Post-walk recap "Open in app" deeplink from the portal
	      (woofwalk://walk/{walkSessionId}).
	    * Team invitation emails (woofwalk://accept-invite?token=<id>).
	    * Future: live-tracking, payment, review, friend-invite hosts.
	  WoofWalkApp's .onOpenURL handles the routing; unknown hosts are
	  silently ignored so we never crash on a deeplink we don't yet
	  recognise.
	-->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.woofwalk</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>woofwalk</string>
			</array>
		</dict>
	</array>
	<!--
	  WoofWalk is dark-first single-mode across iOS / Android / Web.
	  Forcing UIUserInterfaceStyle = Dark prevents the system from
	  flipping the app to light mode during the day, which would
	  break brand colour contrast (turquoise tokens are tuned for
	  dark surfaces). Mirrors Android's locked dark theme.
	-->
	<key>UIUserInterfaceStyle</key>
	<string>Dark</string>

	<!--
	  Google Mobile Ads (AdMob) — gates the charity-points award the
	  same way Android's CharityAdManager does. The user watches a
	  rewarded interstitial before each walk; the reward callback
	  flips charityAdWatched=true so recordCharityPoints() at walk-end
	  awards points.

	  Provisioned 2026-05-06 in the same AdMob account as Android
	  (publisher ca-app-pub-6114201892028196). Approval status is
	  "Requires review" until the iOS app ships to a public store —
	  ad serving is limited until then but test ads serve fully.
	-->
	<key>GADApplicationIdentifier</key>
	<string>ca-app-pub-6114201892028196~9167251061</string>

	<!--
	  ATT (App Tracking Transparency) — iOS 14.5+ requires this
	  description and an explicit prompt before the SDK can request
	  IDFA. CharityAdManager calls ATTrackingManager.requestAuthorization
	  before its first ad load. Even if the user denies, ads still
	  serve (just non-personalised, lower CPM). Charity points still
	  award on reward — the gate is "did they watch the ad", not "did
	  they grant tracking".
	-->
	<key>NSUserTrackingUsageDescription</key>
	<string>WoofWalk shows you a rewarded ad before each charity walk so we can pay your chosen dog rescue charity. Allowing tracking helps us show ads that fund more donations per view.</string>

